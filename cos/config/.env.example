# COS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env no Git.

# ─────────────────────────────────────────────
#  TRELLO
# ─────────────────────────────────────────────
# Obtenha em: https://trello.com/app-key
TRELLO_API_KEY=sua_api_key_aqui

# Clique em "Token" na página acima para gerar
TRELLO_TOKEN=seu_token_aqui

# ID do board de licitações (rode --list-boards para descobrir)
TRELLO_BOARD_ID=id_do_board_aqui

# ─────────────────────────────────────────────
#  FUTURAS INTEGRAÇÕES
# ─────────────────────────────────────────────
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# SUPABASE_URL=
# SUPABASE_KEY=
